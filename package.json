{
	"name": "@akirco/termimg",
	"version": "0.1.0",
	"description": "Terminal image preview library — Kitty, Sixel, HalfBlock, Braille, ASCII",
	"module": "src/index.ts",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"type": "module",
	"bin": {
		"termimg": "dist/cli.js"
	},
	"scripts": {
		"cli": "bun run src/cli.ts",
		"build": "bun build src/index.ts --format esm --outdir dist --target node && bun build src/cli.ts --format esm --outdir dist --target node && tsc -p tsconfig.build.json",
		"build:cli": "bun build src/cli.ts --compile --outfile termimg --target bun",
		"prepublishOnly": "bun run build",
		"format": "bunx biome check --write"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist/",
		"package.json",
		"LICENSE",
		"README.md"
	],
	"devDependencies": {
		"@types/bun": "latest"
	},
	"peerDependencies": {
		"typescript": "*"
	},
	"dependencies": {
		"jimp": "^1.6.1"
	},
	"license": "AGPL-3.0-or-later"
}
