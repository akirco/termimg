{
	"name": "ink",
	"version": "0.0.0",
	"license": "MIT",
	"bin": "dist/cli.js",
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsc",
		"dev": "bun src/cli.tsx",
		"test": "prettier --check . && xo && ava"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"ink": "^7.1.0",
		"jimp": "^1.6.1",
		"meow": "^14.1.0",
		"react": "^19.2.7"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^8.1.0",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@vdemedes/prettier-config": "^2.0.1",
		"ava": "^8.0.1",
		"chalk": "^5.6.2",
		"eslint-config-xo-react": "^0.31.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"ink-testing-library": "^4.0.0",
		"prettier": "^3.9.1",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"xo": "^3.0.2"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	},
	"prettier": "@vdemedes/prettier-config"
}
